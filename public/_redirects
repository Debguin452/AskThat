# Cloudflare Pages _redirects
# NOTE: 404.html is served automatically — do NOT add a /* catch-all here.
# A wildcard /* causes ERR_TOO_MANY_REDIRECTS and breaks the entire site.

/ask/*         /ask.html        200
/dashboard/*   /dashboard.html  200
/about         /about.html      200
/privacy       /privacy.html    200
/terms         /terms.html      200
/faq           /faq.html        200
/security      /.well-known/security.txt  302
